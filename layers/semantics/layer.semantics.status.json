					}
				},
				"info": {
					"strong": {
						"background": { "$type": "color", "$value": "{base.palette.info.800}" },
						"text":       { "$type": "color", "$value": "{semantics.color.on.info.strong}" },
						"stroke":     { "$type": "color", "$value": "{semantics.color.border.info.strong}" }
					},
					"weak": {
						"background": { "$type": "color", "$value": "{base.palette.info.200}" },
						"text":       { "$type": "color", "$value": "{base.palette.info.800}" },
						"stroke":     { "$type": "color", "$value": "{semantics.color.border.info.weak}" }
					}
				}
			}
		}
	}

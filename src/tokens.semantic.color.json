            "hover":    { "$type": "color", "$value": "{Semantics.color.palette.info.100}" },
            "active":   { "$type": "color", "$value": "{Semantics.color.palette.info.200}" },
            "disabled": { "$type": "color", "$value": "rgba(0,0,0,0)" }
